[Unit]
Description=CrediVision Kiosk Display
After=credivision-app.service
Wants=credivision-app.service

[Service]
Type=simple
User=informa
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/informa/.Xauthority
ExecStartPre=/bin/sleep 30
ExecStart=/home/informa/Documentos/CrediVision/start_kiosk.sh fullscreen
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
